{
  "buildCommand": "npm run build --workspace @verida/shared && npm run build --workspace @verida/web",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "installCommand": "npm install",
  "env": {
    "VITE_API_URL": "https://verida-api-5ruj.onrender.com"
  },
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
