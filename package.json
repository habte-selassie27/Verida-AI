{
  "name": "verida-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @verida/web & npm run dev --workspace @verida/api & wait",
    "build": "npm run build --workspace @verida/shared && npm run build --workspace @verida/api && npm run build --workspace @verida/web",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "~5.9.3"
  }
}
